# Claude Code Agents 模板配置。
# 将此文件复制为 .env 后再填写真实密钥；不要把真实密钥提交到 Git。
# 用户级长期配置也可以放到 ~/.config/claude-code-agents/.env。

CLAUDE_BIN=claude
CLAUDE_DEFAULT_MODEL=sonnet
CLAUDE_DEFAULT_EFFORT=high
CLAUDE_DEFAULT_PERMISSION_MODE=auto
CLAUDE_DEFAULT_TIMEOUT_MS=1800000
CLAUDE_DEFAULT_OUTPUT_FORMAT=json

# 可选网关配置。直接使用 Claude 登录时保持为空。
# CLAUDE_DEFAULT_GATEWAY_URL 会传给 Claude Code 的 ANTHROPIC_BASE_URL。
# auth_token -> ANTHROPIC_AUTH_TOKEN
# api_key -> ANTHROPIC_API_KEY
CLAUDE_DEFAULT_GATEWAY_URL=
CLAUDE_DEFAULT_API_KEY=
CLAUDE_DEFAULT_API_KEY_KIND=auth_token

# 可选：额外注入子进程环境变量，使用 JSON 对象。
# CLAUDE_DEFAULT_EXTRA_ENV_JSON={"HTTP_PROXY":"http://127.0.0.1:7890"}

# 每个智能体都可覆盖默认模型、思考强度、权限、网关和凭据。
# 模型名称由用户自己的 Claude 账户或 API 网关决定；不设置时继承 CLAUDE_DEFAULT_*。
# 权限可选：default、acceptEdits、auto、bypassPermissions、dontAsk、plan。
# bypassPermissions 风险较高，仅在用户明确理解并接受风险时使用。

# 架构师（内置默认权限：plan）
# ARCHITECT_MODEL=
# ARCHITECT_EFFORT=xhigh
# ARCHITECT_PERMISSION_MODE=plan

# 后端工程师
# BACKEND_ENGINEER_MODEL=
# BACKEND_ENGINEER_EFFORT=high
# BACKEND_ENGINEER_PERMISSION_MODE=auto

# 前端工程师
# FRONTEND_ENGINEER_MODEL=
# FRONTEND_ENGINEER_EFFORT=high
# FRONTEND_ENGINEER_PERMISSION_MODE=auto
# FRONTEND_ENGINEER_BROWSER_MCP_CONFIGS_JSON={"playwright":"/absolute/path/to/playwright-mcp.json"}

# UI 设计师
# UI_DESIGNER_MODEL=
# UI_DESIGNER_EFFORT=high
# UI_DESIGNER_PERMISSION_MODE=auto
# UI_DESIGNER_BROWSER_MCP_CONFIGS_JSON={"playwright":"/absolute/path/to/playwright-mcp.json"}

# 全栈工程师
# FULLSTACK_ENGINEER_MODEL=
# FULLSTACK_ENGINEER_EFFORT=high
# FULLSTACK_ENGINEER_PERMISSION_MODE=auto

# 测试工程师（QA）
# QA_ENGINEER_MODEL=
# QA_ENGINEER_EFFORT=medium
# QA_ENGINEER_PERMISSION_MODE=auto
# 可选：浏览器 MCP profile 名称到绝对配置文件路径的映射。run_agent 只能选择名称，不能传任意路径。
# QA_ENGINEER_BROWSER_MCP_CONFIGS_JSON={"playwright":"/absolute/path/to/playwright-mcp.json"}

# 安全工程师（内置默认权限：plan）
# SECURITY_ENGINEER_MODEL=
# SECURITY_ENGINEER_EFFORT=xhigh
# SECURITY_ENGINEER_PERMISSION_MODE=plan

# DevOps/SRE 工程师
# DEVOPS_ENGINEER_MODEL=
# DEVOPS_ENGINEER_EFFORT=high
# DEVOPS_ENGINEER_PERMISSION_MODE=auto

# 单个智能体的网关与凭据示例（按需取消注释）：
# BACKEND_ENGINEER_GATEWAY_URL=https://your-api-gateway.example.com/v1
# BACKEND_ENGINEER_API_KEY=replace-me
# BACKEND_ENGINEER_API_KEY_KIND=auth_token

# Phase 1 runner selection. Omitting runner preserves Claude compatibility.
CLAUDE_DEFAULT_RUNNER=claude
CLAUDE_DEFAULT_TIMEOUT_MS=1800000
CODEX_BIN=codex
CODEX_DEFAULT_MODEL=gpt-5-codex
CODEX_DEFAULT_PERMISSION_MODE=auto
CODEX_DEFAULT_OUTPUT_FORMAT=stream-json
# Role x runner overrides take precedence over role-only settings, for example:
# BACKEND_ENGINEER_CODEX_MODEL=gpt-5-codex
# BACKEND_ENGINEER_CODEX_PERMISSION_MODE=auto
# BACKEND_ENGINEER_CODEX_BIN=/absolute/path/to/mock-codex
# Canonical runner defaults: DEFAULT_RUNNER, <ROLE>_DEFAULT_RUNNER,
# <ROLE>_<RUNNER>_* and <RUNNER>_DEFAULT_*; legacy CLAUDE_DEFAULT_RUNNER
# and <ROLE>_RUNNER remain supported.
# DEFAULT_RUNNER=claude
# BACKEND_ENGINEER_DEFAULT_RUNNER=codex
# BACKEND_ENGINEER_CODEX_MODEL=gpt-5-codex
# BACKEND_ENGINEER_CODEX_PERMISSION_MODE=auto
# CODEX_DEFAULT_MODEL=gpt-5-codex
